# macOS
.DS_Store

# Build artifacts (regenerated by build.sh — never committed)
*.app/
*.dmg
*.icns
*.iconset/
/build/

# Signing material — MUST never be committed to a public repo
*.p12
*.pem
*.cer
*.certSigningRequest
ExportOptions.plist

# Sparkle signing keys (added later) — private key must stay local
sparkle_private_key*
dsa_priv.pem
